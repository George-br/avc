#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: buildVars.py:21
msgid "Audio Video Converter"
msgstr "Audio Video Converter"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid ""
"Converts a YouTube video or a multimedia link to MP3 or MP4 directly from "
"the browser:\n"
"\tNVDA+y, Converts the current video to MP3\n"
"\tNVDA+Shift+y, Converts the current video to MP4\n"
"\tNVDA+Control+y, Opens the folder with the converted files\n"
"\tNVDA+Alt+y, Saves the subtitle of the video as text."
msgstr ""
"Chuyển đổi video YouTube hoặc liên kết đa phương tiện sang MP3 hoặc MP4 trực "
"tiếp từ trình duyệt:\n"
"\tNVDA+y, Chuyển đổi video hiện tại sang mp3\n"
"\tNVDA+Shift+y, Chuyển đổi video hiện tại sang mp4\n"
"\tNVDA+Control+y, Mở thư mục với file đã chuyển đổi\n"
"\tNVDA+Alt+y, Lưu phụ đề của video dưới dạng văn bản"

