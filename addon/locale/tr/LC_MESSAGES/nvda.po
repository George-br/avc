#. Translator: Title of error dialog "Folder does not exist"
#: addon\globalPlugins\AVC\__init__.py:930
msgid "Error - Folder does not exist"
msgstr "Hata - Klasör mevcut değil"

#: addon\globalPlugins\AVC\__init__.py:933
#, python-brace-format
msgid ""
"The folder ({folderPath}) does not exist.\n"
"Please check the path or use the Browse button.\n"
"The changes were not saved."
msgstr ""
"Klasör ({folderPath}) mevcut değil.\n"
"Lütfen hedef yolu kontrol edin veya Gözat düğmesini kullanın.\n"
"Değişiklikler kaydedilemedi."

#. Translator: Title of error dialog "No write access to folder"
#: addon\globalPlugins\AVC\__init__.py:951
msgid "Error - No write access to folder"
msgstr "Hata - Klasöre yazma erişimi yok"

#: addon\globalPlugins\AVC\__init__.py:954
#, python-brace-format
msgid ""
"No write access to folder {folderPath} (Code: {code})\n"
"Please select a folder with write access.\n"
"The changes were not saved."
msgstr ""
"{folderPath} klasörüne yazma erişimi yok (Kod: {code})\n"
"Lütfen yazma erişimi olan bir klasör seçin.\n"
"Değişiklikler kaydedilemedi."

