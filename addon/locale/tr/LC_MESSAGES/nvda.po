msgid "No browser window found"
msgstr "Tarayıcı penceresi bulunamadı"

#. Translators: No URL found in browser document, function terminate
#: addon\globalPlugins\AVC\__init__.py:790
#: addon\globalPlugins\AVC\__init__.py:1182
msgid "Document URL not found - exit"
msgstr "Belge Bağlantısı bulunamadı - çık"

