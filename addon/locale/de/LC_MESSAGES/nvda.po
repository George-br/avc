#. Translators: Title of the window if an error occurred during unpacking.
#: addon\installTasks.py:63
msgid "Attention - error when unpacking"
msgstr "Achtung - Fehler beim entpacken"

#: addon\installTasks.py:66
#, python-brace-format
msgid ""
"The file {file} could not be unpacked correctly in the folder {folder}. \n"
"Try it yourself locally or contact the author of this extension."
msgstr ""
"Die Datei {file} konnte im Ordner {folder} nicht korrekt entpackt werden.\n"
"Probieren Sie es selbst vor Ort aus oder kontaktieren Sie den Autor dieser "
"Erweiterung."

#. Translators: Could not create  folder.
#: addon\globalPlugins\AVC\__init__.py:544
msgid "Error - can not create folder"
msgstr "Fehler – Ordner kann nicht erstellt werden"

#. Translators: The user is not in a browser.
#: addon\globalPlugins\AVC\__init__.py:598
msgid "No browser window found"
msgstr "Kein Browserfenster gefunden."

#. Translators: No URL found in browser document, function terminate
#: addon\globalPlugins\AVC\__init__.py:786
#: addon\globalPlugins\AVC\__init__.py:1177
msgid "Document URL not found - exit"
msgstr "Seiten-URL nicht gefunden – Beenden"

#. Translators: save YouTube Video as MP3 or MP4
#: addon\globalPlugins\AVC\__init__.py:797
#, python-brace-format
