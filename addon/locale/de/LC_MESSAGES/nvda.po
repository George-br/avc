msgstr "YouTube-Video speichern als {MultimediaFormat}."

#. Translators: save multimedia link  as MP3 or MP4
#: addon\globalPlugins\AVC\__init__.py:832
#, python-brace-format
msgid "Save link as {MultimediaFormat}"
msgstr "Link speichern als {MultimediaFormat}."

#. Translators: No YouTube video and no multimedia link found
#: addon\globalPlugins\AVC\__init__.py:839
