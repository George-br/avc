#. Translators: Title of the window if an error occurred during unpacking.
#: addon\installTasks.py:63
msgid "Attention - error when unpacking"
msgstr "Atenção - erro ao descomprimir"

#: addon\installTasks.py:66
#, python-brace-format
msgid ""
"The file {file} could not be unpacked correctly in the folder {folder}. \n"
"Try it yourself locally or contact the author of this extension."
msgstr ""
"O ficheiro {file} não pôde ser descompactado corretamente na pasta "
"{folder}.\n"
"Experimente descompactá-lo você mesmo localmente ou contacte o autor deste "
"extra."

#. Translators: Could not create  folder.
#: addon\globalPlugins\AVC\__init__.py:548
msgid "Error - can not create folder"
msgstr "Erro - não é possível criar a pasta"

#. Translators: The user is not in a browser.
#: addon\globalPlugins\AVC\__init__.py:602
msgid "No browser window found"
msgstr "Não foi encontrada nenhuma janela do navegador"

#. Translators: No URL found in browser document, function terminate
#: addon\globalPlugins\AVC\__init__.py:790
#: addon\globalPlugins\AVC\__init__.py:1182
msgid "Document URL not found - exit"
msgstr "URL do documento não encontrado - sair"

#. Translators: save YouTube Video as MP3 or MP4
#: addon\globalPlugins\AVC\__init__.py:801
#, python-brace-format
msgid "Save YouTube Video as {MultimediaFormat}"
msgstr "Guardar vídeo do YouTube como {MultimediaFormat}"

#. Translators: save multimedia link  as MP3 or MP4
#: addon\globalPlugins\AVC\__init__.py:836
#, python-brace-format
msgid "Save link as {MultimediaFormat}"
msgstr "Guardar ligação como {MultimediaFormat}"

#. Translators: No YouTube video and no multimedia link found
#: addon\globalPlugins\AVC\__init__.py:843
msgid "No YouTube video and no multimedia link found"
msgstr ""
"Não foi encontrado nenhum vídeo do YouTube nem nenhuma ligação multimédia"

